# Backend
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
DATABASE_URL=sqlite:///./data/specpilot.db
ARTIFACT_ROOT=./data/runs
CHROMA_PERSIST_DIR=./data/chroma

# 4ga Boards
DOCS_BASE_URL=https://docs.4gaboards.com/
TARGET_APP_URL=https://demo.4gaboards.com/
FOURGA_USERNAME=
FOURGA_PASSWORD=

# Models
TEXT_LLM_PROVIDER=openai_compatible
OPENAI_COMPATIBLE_PROVIDER_NAME=Codex API
OPENAI_COMPATIBLE_HOME_URL=https://openai.com
OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-5.5
OPENAI_COMPATIBLE_NOTE=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
BROWSER_USE_API_KEY=
BROWSER_USE_MODEL=bu-latest
BROWSER_USE_LLM_FALLBACK_ENABLED=false
BROWSER_USE_CLOUD_BROWSER_ENABLED=false
GLM_API_KEY=
GLM_VISION_MODEL=glm-4.6v

# Agent execution
BROWSER_HEADLESS=true
BROWSER_ALLOWED_DOMAINS=*.4gaboards.com
MAX_SCENARIO_STEPS=20
RUN_RETRY_LIMIT=1
VERIFICATION_SNAPSHOT_DELAY_MS=500
NETWORK_IDLE_TIMEOUT_MS=3000
VISION_CONFIDENCE_HIGH=0.85
VISION_CONFIDENCE_LOW=0.60

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
